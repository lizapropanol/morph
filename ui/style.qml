                            layer.enabled: true
                            layer.effect: ColorOverlay { color: "white" }
                        }
                        
                        Text { 
                            text: "MORPH"
                            color: "white"
                            font.family: mainFont.name
                            font.pixelSize: 22
                            font.weight: Font.Black
                            anchors.verticalCenter: parent.verticalCenter
                            anchors.left: logoImg.right
                            anchors.leftMargin: 10
